[
  {
    "id": "airflow",
    "name": "Apache Airflow",
    "icon_url": "/images/resource-templates/airflow.png",
    "image": "apache/airflow",
    "description": "Workflow orchestration stack split into dedicated Airflow runtime services.",
    "color": "#017CEE",
    "abbr": "AF",
    "tags": ["3.0.2", "3.0.1", "3.0.0", "2.10.5", "2.9.3"],
    "shared_env": [
      {
        "key": "AIRFLOW__CORE__EXECUTOR",
        "value": "CeleryExecutor"
      },
      {
        "key": "AIRFLOW__DATABASE__SQL_ALCHEMY_CONN",
        "value": "postgresql+psycopg2://airflow:airflow@postgres:5432/airflow"
      },
      {
        "key": "AIRFLOW__CELERY__BROKER_URL",
        "value": "redis://redis:6379/0"
      },
      {
        "key": "AIRFLOW__CORE__FERNET_KEY",
        "value": "change-me"
      },
      {
        "key": "AIRFLOW__CORE__SECRET_KEY",
        "value": "change-me"
      },
      {
        "key": "AIRFLOW__SIMPLE_AUTH_MANAGER__PASSWORDS",
        "value": "admin:admin"
      }
    ],
    "components": [
      {
        "id": "db-migrate",
        "name": "DB Migrate",
        "description": "Runs airflow db migrate once before services start. Ensures schema is up to date.",
        "type": "job",
        "required": true,
        "default_enabled": true,
        "ports": [],
        "env": [],
        "volumes": [],
        "cmd": ["db", "migrate"]
      },
      {
        "id": "api-server",
        "name": "API Server",
        "description": "Serves the Airflow REST API and UI (replaces webserver in Airflow 3.x).",
        "type": "service",
        "required": true,
        "default_enabled": true,
        "ports": [{ "host": "8080", "container": "8080" }],
        "env": [
          { "key": "AIRFLOW__API_SERVER__EXPOSE_CONFIG", "value": "false" }
        ],
        "volumes": [
          "airflow/dags:/opt/airflow/dags",
          "airflow/logs:/opt/airflow/logs",
          "airflow/plugins:/opt/airflow/plugins"
        ],
        "cmd": ["api-server"]
      },
      {
        "id": "scheduler",
        "name": "Scheduler",
        "description": "Schedules runnable tasks (no longer parses DAGs in Airflow 3.x).",
        "type": "service",
        "required": true,
        "default_enabled": true,
        "ports": [],
        "env": [],
        "volumes": [
          "airflow/dags:/opt/airflow/dags",
          "airflow/logs:/opt/airflow/logs",
          "airflow/plugins:/opt/airflow/plugins"
        ],
        "cmd": ["scheduler"]
      },
      {
        "id": "dag-processor",
        "name": "DAG Processor",
        "description": "Parses and processes DAG files (new dedicated service in Airflow 3.x).",
        "type": "service",
        "required": true,
        "default_enabled": true,
        "ports": [],
        "env": [],
        "volumes": [
          "airflow/dags:/opt/airflow/dags",
          "airflow/logs:/opt/airflow/logs",
          "airflow/plugins:/opt/airflow/plugins"
        ],
        "cmd": ["dag-processor"]
      },
      {
        "id": "worker",
        "name": "Worker",
        "description": "Executes tasks when CeleryExecutor is enabled.",
        "type": "service",
        "required": false,
        "default_enabled": true,
        "ports": [],
        "env": [],
        "volumes": [
          "airflow/dags:/opt/airflow/dags",
          "airflow/logs:/opt/airflow/logs",
          "airflow/plugins:/opt/airflow/plugins"
        ],
        "cmd": ["celery", "worker"]
      },
      {
        "id": "triggerer",
        "name": "Triggerer",
        "description": "Runs deferrable task triggers and async sensors.",
        "type": "service",
        "required": false,
        "default_enabled": true,
        "ports": [],
        "env": [],
        "volumes": [
          "airflow/dags:/opt/airflow/dags",
          "airflow/logs:/opt/airflow/logs",
          "airflow/plugins:/opt/airflow/plugins"
        ],
        "cmd": ["triggerer"]
      }
    ]
  },
  {
    "id": "openclaw",
    "name": "OpenClaw AI Gateway",
    "icon_url": "/images/resource-templates/openclaw.png",
    "image": "ghcr.io/openclaw/openclaw",
    "description": "Self-hosted AI gateway with unified API for OpenAI, Anthropic, and Gemini models.",
    "color": "#6366f1",
    "abbr": "OC",
    "tags": ["latest"],
    "shared_env": [
      { "key": "HOME", "value": "/home/node" },
      { "key": "TERM", "value": "xterm-256color" },
      { "key": "OPENCLAW_CONFIG_DIR", "value": "/home/node/.openclaw" },
      { "key": "OPENCLAW_WORKSPACE_DIR", "value": "/home/node/.openclaw/workspace" },
      { "key": "OPENCLAW_TMP_DIR", "value": "/home/node/.openclaw/tmp" },
      { "key": "OPENCLAW_GATEWAY_TOKEN", "value": "" },
      { "key": "OPENCLAW_DEFAULT_MODEL", "value": "anthropic/claude-sonnet-4-6" },
      { "key": "ANTHROPIC_API_KEY", "value": "" },
      { "key": "OPENAI_API_KEY", "value": "" },
      { "key": "GEMINI_API_KEY", "value": "" }
    ],
    "components": [
      {
        "id": "gateway",
        "name": "Gateway",
        "description": "OpenClaw AI gateway. Serves the unified AI API on port 18789.",
        "type": "service",
        "required": true,
        "default_enabled": true,
        "ports": [{ "host": "18789", "container": "18789" }],
        "env": [],
        "volumes": ["openclaw-config:/home/node/.openclaw"],
        "cmd": ["node", "dist/index.js", "gateway", "--bind", "lan", "--port", "18789"],
        "volume_files": [
          {
            "path": "openclaw-config/openclaw.json",
            "content": "{\"gateway\":{\"mode\":\"local\",\"bind\":\"lan\",\"auth\":{\"token\":\"{{OPENCLAW_GATEWAY_TOKEN}}\"},\"controlUi\":{\"allowedOrigins\":[\"*\"]}},\"agents\":{\"defaults\":{\"model\":{\"primary\":\"{{OPENCLAW_DEFAULT_MODEL}}\"}}}}"
          },
          {
            "path": "openclaw-config/agents/main/agent/auth-profiles.json",
            "content": "{\"version\":1,\"profiles\":{\"{{OPENCLAW_AUTH_PROVIDER}}:default\":{\"type\":\"api_key\",\"provider\":\"{{OPENCLAW_AUTH_PROVIDER}}\",\"key\":\"{{OPENCLAW_AUTH_KEY}}\"}}}"
          }
        ]
      }
    ]
  }
]
